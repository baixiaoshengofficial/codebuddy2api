# ===============================================================
# CodeBuddy2API - 环境变量示例文件
#
# 使用前，请将此文件复制为 .env 并填写必要的值
# ===============================================================

# -----------------
# 服务端配置
# -----------------

# (必需) API服务的访问密码，客户端连接时需要在Authorization头中提供此密码
CODEBUDDY_PASSWORD=

# (可选) 服务监听的主机地址
# 默认值: 127.0.0.1
CODEBUDDY_HOST=127.0.0.1

# (可选) 服务监听的端口
# 默认值: 8001
CODEBUDDY_PORT=8001


# -----------------
# CodeBuddy API 配置
# -----------------

# (可选) CodeBuddy站点，可选 international(国际站) 或 china(国内站)
# API端点会根据站点自动选择:
# - international -> https://www.codebuddy.ai
# - china -> https://copilot.tencent.com
CODEBUDDY_SITE=international

# (可选) 存放CodeBuddy认证凭证 (JSON文件) 的目录
# 默认值: .codebuddy_creds
CODEBUDDY_CREDS_DIR=.codebuddy_creds


# -----------------
# 高级配置
# -----------------

# (可选) 应用的日志级别
# 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
# 默认值: INFO
CODEBUDDY_LOG_LEVEL=INFO

# (可选) CodeBuddy 官方 API SSL 证书验证
# 默认值: false
CODEBUDDY_SSL_VERIFY=false

# (可选) 凭证轮换频率，N次请求后切换凭证，设为0关闭轮换
# 默认值: 1
CODEBUDDY_ROTATION_COUNT=1

# (可选) 自动领取 WorkBuddy / CodeBuddy 每日签到奖励
# 默认值: true
CODEBUDDY_AUTO_CHECKIN=true

# (可选) 每日自动签到时间（北京时间 HH:MM）
# 默认值: 11:00
CODEBUDDY_CHECKIN_TIME=11:00

# (可选) 签到结果推送到 Bark；留空则不推送
# 默认值: https://bark.chenqinfeng.cn/a4K9KCJ56wmgoxyTjPsh3N/
CODEBUDDY_BARK_URL=https://bark.chenqinfeng.cn/a4K9KCJ56wmgoxyTjPsh3N/
